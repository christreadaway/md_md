{
  "name": "claude-md-updater",
  "version": "1.0.0",
  "description": "Local web app to sync CLAUDE.md across all GitHub repos",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test --test-reporter=spec 'test/**/*.test.js'",
    "test:watch": "node --test --watch 'test/**/*.test.js'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "express": "^4.18.2",
    "winston": "^3.11.0"
  }
}
